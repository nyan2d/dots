[bar/first]
font-0 = SF Pro Text:style=Semibold:size=14;3
font-1 = JetBrainsMono Nerd Font:pixelsize=16;3:antialias=true:hinting=true
width = 100%
height = 36
background = #60000000
fixed-center = true
modules-left = hostname i3
modules-right = layout volume eth weather date
tray-position = right
tray-padding = 1

[bar/second]
monitor=DVI-D-0
font-0 = SF Pro Text:style=Semibold:size=14;3
font-1 = JetBrainsMono Nerd Font:pixelsize=16;3:antialias=true:hinting=true
width = 100%
height = 30
background = #60000000
fixed-center = true
modules-left = hostname i3
modules-right = date

[module/date]
type = internal/date
date = "%A, %B %e."
date-alt = " %Y-%m-%d"
time = "%H:%M"
time-alt = "%H:%M:%S"
label = %date% %time%
format-padding = 1

[module/eth]
type = internal/network
interface = eth0
label-connected = " "
label-disconnected = "Disconnected"
format-disconnected-prefix = " "
format-connected-padding = 1
format-disconnected-padding = 1

[module/volume]
type = internal/pulseaudio
use-ui-max = true
format-volume = "<ramp-volume> <label-volume>"
format-volume-padding = 1
label-muted = "  婢   "
ramp-volume-0 = "奄"
ramp-volume-1 = "奔"
ramp-volume-2 = "墳"
click-right = pavucontrol

[module/layout]
type = internal/xkeyboard
blacklist-0 = num lock
blacklist-1 = scroll lock
blacklist-2 = caps lock
label-layout = %icon%
layout-icon-0 = us;EN
layout-icon-1 = ru;RU
format = <label-layout>
format-prefix = "   "
format-padding = 1

[module/title]
type = internal/xwindow
label-maxlen = 80

[module/i3]
type = internal/i3
pin-workspaces = true
index-sort = true
label-focused = %index%
label-focused-background = #2acccccc
label-focused-padding = 3
label-unfocused = %index%
label-unfocused-padding = 3
label-urgent = %index%
label-urgent-background = #ff0000
label-urgent-padding = 3
label-visible = "%index%"
label-visible-padding = 3
label-visible-background = #09cccccc

[module/hostname]
type = custom/script
exec = uname -n
interval = 300.0
format = "  <label>"
format-padding = 10
