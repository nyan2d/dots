[bar/first]
font-0 = JetBrainsMono Nerd Font:size=12.0;3
width = 100%
height = 36
background = #1f2430
fixed-center = true
modules-left = hostname i3
modules-right = layout volume eth weather date
tray-position = right
tray-padding = 1

[bar/second]
monitor=DVI-D-0
font-0 = JetBrainsMono Nerd Font:size=12.0;3
width = 100%
height = 30
background = #1f2430
fixed-center = true
modules-left = hostname i3
modules-right = date

[module/date]
type = internal/date
date = ""
date-alt = " %Y-%m-%d"
time = "%H:%M"
time-alt = "%H:%M:%S"
label = %date% %time%
format-prefix = ""
format-prefix-foreground = "#ff66b5"
format-padding = 1

[module/eth]
type = internal/network
interface = enp9s0
label-connected = "Ethernet"
label-connected-alt = "AYE"
label-disconnected = "Disconnected"
format-connected-prefix = " "
format-connected-prefix-foreground = "#ff66b5"
format-disconnected-prefix = " "
format-disconnected-prefix-foreground = "#ff66b5"
format-connected-padding = 1
format-disconnected-padding = 1

[module/volume]
type = internal/pulseaudio
use-ui-max = true
format-volume = "<ramp-volume> <label-volume>"
format-volume-padding = 1
label-muted = "ﱝ  "
label-muted-foreground = "#ff0000"
ramp-volume-0 = "奄"
ramp-volume-1 = "奔"
ramp-volume-2 = "墳"
ramp-volume-foreground = "#ff66b5"
click-right = pavucontrol

[module/layout]
type = internal/xkeyboard
blacklist-0 = num lock
blacklist-1 = scroll lock
blacklist-2 = caps lock
label-layout = %icon%
layout-icon-0 = us;EN
layout-icon-1 = ru;RU
format = <label-layout>
format-prefix = "  "
format-prefix-foreground = "#ff66b5"
format-padding = 1

[module/title]
type = internal/xwindow
label-maxlen = 80

[module/i3]
type = internal/i3
pin-workspaces = true
index-sort = true
label-focused = %index%
label-focused-background = #2acccccc
label-focused-padding = 1
label-unfocused = %index%
label-unfocused-padding = 1
label-urgent = %index%
label-urgent-background = #ff0000
label-urgent-padding = 1
label-visible = "%index%"
label-visible-padding = 1
label-visible-background = #09cccccc

[module/hostname]
type = custom/script
exec = uname -n
interval = 300.0
format =  <label>
format-padding = 1

[module/weather]
type = custom/script
exec = ~/go/bin/weather
interval = 600.0
format-prefix = "  "
format-prefix-foreground = "#ff66b5"
format = "<label>"
format-padding = 1
